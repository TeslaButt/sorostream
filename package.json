{
  "name": "sorostream",
  "version": "0.0.0",
  "packageManager": "npm@10.8.2",
  "private": true,
  "workspaces": [
    "packages/frontend"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
